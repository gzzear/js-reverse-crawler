# pkg_service 环境变量模板 — 部署时复制为 .env 再填值
# .env 本身 gitignored，密钥类信息只通过手工分发

# ---- 数据源 ----
# 阿里云 RDS 上的 mdkd 独立库
DB_URL=mysql+pymysql://<user>:<pass>@<host>:3306/mdkd?charset=utf8mb4

# 阿里云共享 Redis（key 都带 pkgsvc: 前缀，不会踩到其他业务）
REDIS_URL=redis://:<pass>@<host>:6379/0

# ---- 运行期 ----
LOG_LEVEL=INFO

# Node worker pool 数量（anti-content 生成）。0aq + mdkd 各一个
POOL_SIZE=2

# 业务节奏
POLL_INTERVAL_SEC=600              # 稳态轮询 10 min
ON_DEMAND_COOLDOWN_SEC=30          # 触发式兜底节流
SESSION_REFRESH_INTERVAL_SEC=10200 # SUB_PASS_ID 刷新 2h50m

# ---- 微信小程序凭证（M4 上线前填）----
WX_APPID=
WX_SECRET=

# ---- 管理端鉴权 ----
# 保护 /v1/admin/*（站长登录、账号管理）。留空则整组路由 503
# 生成：python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# ---- mdkd 出站代理（住宅/家宽静态 IP，过 PDD 风控）----
# ECS 机房 IP 发短信/登录必被拒（40001/4000003），必须经家宽代理
# 两种模式二选一：
#
# 【模式 A · 静态 URL】一个固定 IP，直接填：
#   MDKD_PROXY=http://<user>:<pass>@<ip>:<port>
# 快代理独享 / 固定 IP 套餐 / 隧道 tpsXXXX.kdlapi.com:15818 都走这条
#
# 【模式 B · 动态 API】快代理"私密代理 kps"：启动调 API 拉 IP、TTL 内复用
#   MDKD_PROXY=
#   MDKD_PROXY_FETCH_URL=https://kps.kdlapi.com/api/getkps/?secret_id=xxx&signature=xxx&num=1&sep=1
#   MDKD_PROXY_USER=<代理用户名>
#   MDKD_PROXY_PASS=<代理密码>
#   MDKD_PROXY_TTL_SEC=600   # IP 缓存秒数（默认 10 min，勿长于快代理 IP 生命期）
#
# 本地/家用网络直跑时全留空
MDKD_PROXY=
MDKD_PROXY_FETCH_URL=
MDKD_PROXY_USER=
MDKD_PROXY_PASS=
MDKD_PROXY_TTL_SEC=600
