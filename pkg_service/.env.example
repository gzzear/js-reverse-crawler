# pkg_service 环境变量模板 — 部署时复制为 .env 再填值
# .env 本身 gitignored，密钥类信息只通过手工分发

# ---- 数据源 ----
# 阿里云 RDS 上的 mdkd 独立库
DB_URL=mysql+pymysql://<user>:<pass>@<host>:3306/mdkd?charset=utf8mb4

# 阿里云共享 Redis（key 都带 pkgsvc: 前缀，不会踩到其他业务）
REDIS_URL=redis://:<pass>@<host>:6379/0

# ---- 运行期 ----
LOG_LEVEL=INFO

# Node worker pool 数量（anti-content 生成）。0aq + mdkd 各一个
POOL_SIZE=2

# 业务节奏
POLL_INTERVAL_SEC=600              # 稳态轮询 10 min
ON_DEMAND_COOLDOWN_SEC=30          # 触发式兜底节流
SESSION_REFRESH_INTERVAL_SEC=10200 # SUB_PASS_ID 刷新 2h50m

# ---- 微信小程序凭证（M4 上线前填）----
WX_APPID=
WX_SECRET=
